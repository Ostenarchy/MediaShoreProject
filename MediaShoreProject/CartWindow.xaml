<Window x:Class="MediaShoreProject.CartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MediaShoreProject"
        mc:Ignorable="d"
        Title="CartWindow" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>

        <ListBox x:Name="lbCartItems" Grid.Row="0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Discs.discName}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding PriceAtTime, StringFormat='{}{0} руб.'}" VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <!-- Кнопки изменения количества -->
                            <Button Content="-" Width="30" Click="btnMinus_Click" Tag="{Binding id}"/>
                            <TextBlock Text="{Binding quantity}" Margin="10,0" FontSize="18" VerticalAlignment="Center"/>
                            <Button Content="+" Width="30" Click="btnPlus_Click" Tag="{Binding id}"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="1" VerticalAlignment="Bottom">
            <TextBlock x:Name="txtTotalSum" Text="Итого: 0 руб." FontSize="20" FontWeight="Bold"/>
            <Button x:Name="btnCheckout" Content="Оформить заказ" Height="40" Click="btnCheckout_Click" Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</Window>

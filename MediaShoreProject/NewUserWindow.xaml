<Window x:Class="MediaShoreProject.NewUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MediaShoreProject"
        mc:Ignorable="d"
        Title="Регистрация" Height="325" Width="333"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <StackPanel Margin="10">
            <TextBlock Text="*Логин:"/>
            <TextBox x:Name="tbLogin" />
            <TextBlock Text="*Пароль:"/>
            <PasswordBox x:Name="pbPassword"/>
            <TextBlock Text="*Подтверждение пароля"/>
            <PasswordBox x:Name="pbPasswordConfirmed"/>
            <TextBlock Text="Имя:"/>
            <TextBox x:Name="tbFirstName"/>
            <TextBlock Text="Фамилия: "/>
            <TextBox x:Name="tbLastName"/>
            <TextBlock Text="*EMail:"/>
            <TextBox x:Name="tbEmail"/>
            <StackPanel Margin="10,20,10,10" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnSave" Content="Зарегистрироваться" Height="27" Width="127" Background="LimeGreen" Foreground="Black" Click="btnSave_Click"/>
                <Button x:Name="btnCancel" Content="Отмена" Margin="10,0,0,0" Width="62" Background="red" Foreground="White" Click="btnCancel_Click"/>
            </StackPanel>
        </StackPanel>
        <StackPanel Margin="10" VerticalAlignment="Bottom">
            <TextBlock Opacity="0.72" Text="* - Обязательные поля"/>
        </StackPanel>
    </Grid>
</Window>

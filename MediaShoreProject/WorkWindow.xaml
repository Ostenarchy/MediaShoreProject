<Window x:Class="MediaShoreProject.WorkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MediaShoreProject"
        mc:Ignorable="d"
        Title="WorkWindow" Height="678" Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        
            <StackPanel Grid.Row="0" HorizontalAlignment="Left">
                <Button x:Name="btnDisconnect" Content="Выйти" Background="red" Foreground="white" Click="btnDisconnect_Click" Width="100" Height="51" FontSize="22"/>
                
            </StackPanel>


        <ListBox Grid.Row="1" x:Name="lbDisc" ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="400"/>
                                <ColumnDefinition Width="300"/>
                            </Grid.ColumnDefinitions>
                            <Image Grid.Column="0" Source="{Binding discCoverPath}" Margin="0,0,10,0" Width="100" Height="100"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding discName}" FontSize="22"/>
                                <TextBlock Text="{Binding Authors.authorFullName}"/> <!-- НЕ ЗАБУДЬ ТУТА // не забыл!-->
                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                    <TextBlock Text="{Binding ReleaseDate}" FontStyle="Italic" FontSize="10"/>
                                    <TextBlock Text=" / "/>
                                    <TextBlock Text="{Binding DiscGenres.genreName}" FontStyle="Italic" FontSize="10"/>
                                    
                                </StackPanel>
                            <TextBlock Text="{Binding discDescription}" FontSize="18" TextWrapping="WrapWithOverflow"/> 
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{Binding quantity}" FontSize="26"/>
                            <TextBlock Text="{Binding price}"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Width="30" Height="30" Content="+" x:Name="btnAddToCart" Click="btnAddToCart_Click"/> <!--кнопочка-->
                            </StackPanel>
                        </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            
        

        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <TextBlock x:Name="textBlockUserRole" Text="ROLE:"/>
            <TextBlock Margin="5,0,0,0" x:Name="textBlockUserFIO" Text="NICKNAME"/>
        </StackPanel>

    </Grid>
</Window>

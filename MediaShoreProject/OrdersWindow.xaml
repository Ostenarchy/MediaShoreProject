<Window x:Class="MediaShoreProject.OrdersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Панель управления данными (Администратор)" Height="650" Width="600" 
        WindowStartupLocation="CenterScreen">
    <Grid>
        <TabControl x:Name="tcAdmin">
            <TabItem Header="Авторы">
                <Grid>
                    <ListBox x:Name="lbAuthors" Margin="10,10,10,70">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="5">
                                    <TextBlock Text="{Binding authorFullName}" FontSize="16"/>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="10">
                        <Button Background="lime" x:Name="btnAddAuthor" Content="Добавить" Width="120" Height="40" Margin="5" Click="btnAddAuthor_Click"/>
                        <Button Background="Orange" x:Name="btnEditAuthor" Content="Изменить" Width="120" Height="40" Margin="5" Click="btnEditAuthor_Click"/>
                        <Button Background="red" Foreground="White" x:Name="btnDeleteAuthor" Content="Удалить" Width="120" Height="40" Margin="5" Click="btnDeleteAuthor_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Жанры">
                <Grid>
                    <ListBox x:Name="lbGenres" Margin="10,10,10,70">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="5">
                                    <TextBlock Text="{Binding genreName}" FontSize="16"/>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="10">
                        <Button Background="Lime" x:Name="btnAddGenre" Content="Добавить" Width="120" Height="40" Margin="5" Click="btnAddGenre_Click"/>
                        <Button Background="Orange" x:Name="btnEditGenre" Content="Изменить" Width="120" Height="40" Margin="5" Click="btnEditGenre_Click"/>
                        <Button Background="red" Foreground="white" x:Name="btnDeleteGenre" Content="Удалить" Width="120" Height="40" Margin="5" Click="btnDeleteGenre_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Заказы">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
                        <TextBlock Text="Дата:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                        <RadioButton x:Name="rbNew" Content="Сначала новые" IsChecked="True" 
                         Margin="5" Checked="rbSortOrder_Checked"/>
                        <RadioButton x:Name="rbOld" Content="Сначала старые" 
                         Margin="5" Checked="rbSortOrder_Checked"/>
                    </StackPanel>

                    <ListBox Grid.Row="1" x:Name="lbOrders" Margin="10,10,10,70">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Margin="2" Padding="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Users.userLastName, StringFormat='Клиент: {0}'}" FontSize="14" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding orderDateOfPurchase, StringFormat='Дата: {0:dd.MM.yyyy HH:mm}'}" FontSize="12" Foreground="Gray"/>
                                            <TextBlock Text="{Binding Statuses.statusName, StringFormat='Статус: {0}'}" FontStyle="Italic" FontSize="12"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Margin="12,0,0,0" Text="{Binding totalSum}" 
                                                   FontSize="16" VerticalAlignment="Center" Foreground="DarkGreen" FontWeight="Bold"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button Grid.Row="2" Background="Red" Foreground="White" x:Name="btnDeleteOrder" Content="Удалить заказ" VerticalAlignment="Bottom" 
                            HorizontalAlignment="Right" Margin="15" Width="150" Height="40" Click="btnDeleteOrder_Click"/>
                    <Button Grid.Row="2" Background="Lime" x:Name="btnEditStatus" Content="Изменить статус" VerticalAlignment="Bottom" 
        HorizontalAlignment="Left" Margin="15" Width="150" Height="40" Click="btnEditStatus_Click"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
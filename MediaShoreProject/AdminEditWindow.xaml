<Window x:Class="MediaShoreProject.AdminEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MediaShoreProject"
        mc:Ignorable="d"
        Title="Изменение / Удаление" Height="207" Width="381">
    <Grid>
        <StackPanel Margin="20">
            <TextBlock x:Name="lblTitle" Text="Введите название:" Margin="0,0,0,10"/>
            <TextBox x:Name="tbInput" Height="30" VerticalContentAlignment="Center"/>
            <Button Content="Сохранить" Margin="0,20,0,0" Click="Button_Click"/>
        </StackPanel>
    </Grid>
</Window>

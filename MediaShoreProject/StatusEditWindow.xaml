<Window x:Class="MediaShoreProject.StatusEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Изменение статуса" Height="200" Width="300" WindowStartupLocation="CenterOwner">
    <StackPanel Margin="20" VerticalAlignment="Center">
        <TextBlock Text="Выберите новый статус:" Margin="0,0,0,10" FontWeight="Bold"/>
        <ComboBox x:Name="cbStatus" DisplayMemberPath="statusName" Height="30"/>
        <Button Content="Сохранить" Margin="0,20,0,0" Height="35" Click="btnSave_Click" Background="AliceBlue"/>
    </StackPanel>
</Window>
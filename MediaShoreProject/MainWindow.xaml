<Window x:Class="MediaShoreProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MediaShoreProject"
        mc:Ignorable="d"
        Title="Авторизация" Height="611" Width="826"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <StackPanel>
            <Image Source="/cover.png" Width="712" Height="178"/>
            <TextBlock Text="Пожалуйста войдите в аккаунт или зарегистрируйтесь" FontSize="29" HorizontalAlignment="Center"/>
            <TextBlock Text="Логин: " Margin="20,50,10,0" FontSize="25"/>
            <TextBox x:Name="tbLogin" FontSize="25" Margin="20,5,10,0"/>
            <TextBlock Text="Пароль: " Margin="20,5,10,0" FontSize="25"/>
            <PasswordBox x:Name="pbPassword" Margin="20,5,10,0" FontSize="25"/>

            <StackPanel Margin="0,50,0,0" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Войти" FontSize="33" Width="120" Height="66" x:Name="btnLogin" Click="btnLogin_Click"/>
                <Button Margin="20,0,0,0" Content="Зарегистрироваться" FontSize="33" Width="326" Height="66" x:Name="btnReg" Click="btnReg_Click"/>
                <Button Margin="20,0,0,0" Content="Войти как гость" FontSize="33" Width="274" Height="66" x:Name="btnGuest" Click="btnGuest_Click"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</Window>
